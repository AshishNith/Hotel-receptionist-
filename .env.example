# ─── Server Configuration ─────────────────────────────────────────
PORT=3000

# MongoDB URI (Required)
# Used for storing settings, call logs, personas, and campaign queues.
MONGODB_URI="mongodb://localhost:27017/voicelink-ai"

# Public Application URL (Recommended)
# Required for telephony webhooks (VoBiz/SIP) to reach the server.
# e.g., https://your-subdomain.onrender.com or your ngrok URL
APP_URL=""

# ─── Optional Fallbacks (Settings page config overrides these) ───

# Gemini AI (Get from Google AI Studio)
GEMINI_API_KEY=""

# VoBiz Telephony Credentials (Get from console.vobiz.ai)
VOBIZ_AUTH_ID=""
VOBIZ_AUTH_TOKEN=""
VOBIZ_FROM_NUMBER=""

# Google Sheets Database Integration (For CSV syncing)
GOOGLE_SHEETS_SPREADSHEET_ID=""

# ─── Google OAuth Integration (For Workspace Calendar/Gmail) ───
# Create these credentials under Google Cloud Console (OAuth 2.0 Client ID)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"
